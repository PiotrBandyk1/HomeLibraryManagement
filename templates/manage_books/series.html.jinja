{% extends "base.html.jinja" %}

{% block content %}
<div class="p-4 bg-white rounded-lg shadow-md mt-4">
    <h1 class="text-xl font-bold mb-4">Lista Serii</h1>
    <ul class="list-disc list-inside">
        {% for s in series %}
            <li class="py-1">{{ s.name }}</li>
        {% endfor %}
    </ul>
</div>
{% endblock %}