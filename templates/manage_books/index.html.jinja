{% extends "base.html.jinja" %}
{% block title %}Lista książek{% endblock %}
{% block content %}
    <section class="w-full grid grid-cols-[1fr_3fr] gap-4 mt-4">
        <div class="flex flex-col bg-white rounded-lg shadow-md p-4">
            <h3 class="text-md font-semibold mb-2">Filtry</h3>
            <input type="text" placeholder="Szukaj książki..." class="w-full p-2 mb-4 border rounded">
            <ul class="list-disc list-inside">
                <li><a href="#" class="text-blue-500 hover:underline">Wszystkie książki</a></li>
                <li><a href="#" class="text-blue-500 hover:underline">Dostępne</a></li>
                <li><a href="#" class="text-blue-500 hover:underline">Wypożyczone</a></li>
                <li><a href="#" class="text-blue-500 hover:underline">Ulubione</a></li>
            </ul>
        </div>
        <div class="flex flex-col bg-white rounded-lg shadow-md p-4">
            <h3 class="text-md font-semibold mb-2">Książki</h3>
            {% for book in books %}
                <div class="border-b py-2">
                    <a href="{% url 'book' book.id %}" class="text-blue-500 hover:underline">{{ book.title }}</a>
                    <p class="text-sm text-gray-600">{{ book.author }}</p>
                </div>
            {% empty %}
                <p class="text-gray-600">Brak książek do wyświetlenia.</p>
            {% endfor %}
        </div>
    </section>
        
{% endblock %}