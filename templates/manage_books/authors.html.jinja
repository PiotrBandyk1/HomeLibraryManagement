{% extends "base.html.jinja" %}
{% block title %}Lista autorów{% endblock %}
{% block content %}
    <section class="w-full grid gap-4 mt-4">
        <div class="flex flex-col bg-white rounded-lg shadow-md p-4">
            <h3 class="text-md font-semibold mb-2">Autorzy</h3>
            {% for author in authors %}
                <div class="border-b py-2">
                    <a href="{% url 'author' author.id %}" class="text-blue-500 hover:underline">{{ author.last_name }} {{ author.first_name }}</a>
                    {% if author.title %}
                        <p class="text-sm text-gray-600">{{ author.title }}</p>
                    {% endif %}
                </div>
            {% empty %}
                <p class="text-gray-600">Brak autorów do wyświetlenia.</p>
            {% endfor %}
        </div>
    </section>
        
{% endblock %}